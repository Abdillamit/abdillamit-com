      description: 'Website for the software company I work at.',
      stack: ['Gatsby.js', 'TypeScript', 'Apollo', 'Redux', 'AWS web services']
    }
  ],
  ky: [
    {
      name: 'finik.kg',
      url: 'https://finik.kg',
      role: 'SWE / Fullstack',
      description: 'Кыргызстандагы бизнес үчүн төлөм платформасы.',
      stack: ['React', 'TypeScript', 'Apollo', 'Redux', 'AWS web services']
    },
    {
      name: 'slonexpress',
      url: 'https://slonexpress.com',
      role: 'SWE / Fullstack',
      description: 'Жеткирүү тейлөөсү. Колдонуучулар үчүн веб-интерфейс жана заказдарды башкаруу панели.',
