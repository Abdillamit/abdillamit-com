    }
  ]
}

const list = projects[lang]
---

<BaseLayout title={`${t('projects.title')} — Abdillamit`} description={t('projects.title')} lang={lang} pageKey="projects">
  <h1>{t('projects.title')}</h1>
  <ul class="project-list">
    {list.map((project) => (
      <li>
        <h3><a href={project.url}>{project.name}</a></h3>
        <div class="meta">{project.role} · {project.stack.join(', ')}</div>
        <p>{project.description}</p>
      </li>
    ))}
  </ul>
</BaseLayout>
