      stack: ['Gatsby.js', 'TypeScript', 'Apollo', 'Redux', 'AWS web services']
    },
    {
      name: 'ManchoDevs',
      url: 'https://mancho.dev',
      role: 'SWE / Fullstack',
      description: 'Сайт IT-компании, в которой я работаю.',
      stack: ['Gatsby.js', 'TypeScript', 'Apollo', 'Redux', 'AWS web services']
    }
  ],
  en: [
    {
      name: 'finik.kg',
      url: 'https://finik.kg',
      role: 'SWE / Fullstack',
      description: 'Payment platform for businesses in Kyrgyzstan.',
      stack: ['React', 'TypeScript', 'Apollo', 'Redux', 'AWS web services']
    },
    {
      name: 'slonexpress',
      url: 'https://slonexpress.com',
      role: 'SWE / Fullstack',
      description: 'Delivery service. User-facing web app and order management dashboard.',
      stack: ['React', 'TypeScript', 'Apollo', 'Redux', 'AWS web services']
    },
    {
      name: 'mancho.school',
      url: 'https://www.mancho.dev/school/',
      role: 'SWE / Fullstack',
      description: 'Educational platform by ManchoDevs. SWE courses.',
