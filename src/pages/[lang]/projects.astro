---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { type Lang, languages } from '@/i18n/ui'
import { useTranslations } from '@/i18n/utils'

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }))
}

const { lang } = Astro.params as { lang: Lang }
const t = useTranslations(lang)

interface Project {
  name: string
  url: string
  role: string
  description: string
  stack: string[]
}

const projects: Record<Lang, Project[]> = {
  ru: [
    {
      name: 'finik.kg',
      url: 'https://finik.kg',
      role: 'SWE / Fullstack',
      description: 'Платёжная платформа для бизнеса в Кыргызстане.',
      stack: ['React', 'TypeScript', 'Apollo', 'Redux', 'AWS web services']
    },
    {
      name: 'slonexpress',
      url: 'https://slonexpress.com',
